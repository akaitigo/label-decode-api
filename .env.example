# label-decode-api 環境変数サンプル
# 実際の値は .env（gitignore 済み）またはデプロイ環境のシークレット管理に設定する。

# --- データベース ---
DB_USERNAME=labeldecode
DB_PASSWORD=change-me-db-password
DB_URL=jdbc:postgresql://localhost:5432/labeldecode

# --- API キー認証（カンマ区切りで複数指定可）---
# 例: openssl rand -hex 32 で生成する。ハードコード禁止。
API_KEYS=change-me-generate-with-openssl-rand-hex-32

# --- レート制限（省略時: 120 req/分, バースト 30）---
RATE_LIMIT_REQUESTS_PER_MINUTE=120
RATE_LIMIT_BURST_CAPACITY=30

# --- TLS（設定すると gRPC サーバーが TLS で待ち受ける。PEM 形式）---
# QUARKUS_GRPC_SERVER_SSL_CERTIFICATE=/etc/tls/server.crt
# QUARKUS_GRPC_SERVER_SSL_KEY=/etc/tls/server.key
